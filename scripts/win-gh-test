#!/usr/bin/env bash
set -euo pipefail

TEST_SET="${1:-check}"
WORKFLOW="windows-lsb-hardware.yml"

case "$TEST_SET" in
  check | unit | smoke | e2e) ;;
  *)
    echo "Usage: $0 [check|unit|smoke|e2e]" >&2
    exit 2
    ;;
esac

if ! command -v gh >/dev/null 2>&1; then
  echo "GitHub CLI is required: gh" >&2
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

BRANCH="$(git branch --show-current)"

if [[ -z "$BRANCH" ]]; then
  echo "Could not determine current branch." >&2
  exit 1
fi

if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "Working tree has uncommitted changes." >&2
  echo "Create a WIP commit before running Windows hardware tests." >&2
  exit 1
fi

HEAD_SHA="$(git rev-parse HEAD)"

echo "Pushing branch: $BRANCH"
git push -u origin "HEAD:$BRANCH"

echo "Triggering $WORKFLOW on $BRANCH with test_set=$TEST_SET"
gh workflow run "$WORKFLOW" --ref "$BRANCH" -f "test_set=$TEST_SET"

echo "Waiting for the run to appear..."
RUN_ID=""
for _ in {1..12}; do
  RUN_ID="$(
    gh run list \
      --workflow "$WORKFLOW" \
      --branch "$BRANCH" \
      --event workflow_dispatch \
      --limit 10 \
      --json databaseId,headSha \
      --jq ".[] | select(.headSha == \"$HEAD_SHA\") | .databaseId" \
      | head -n 1
  )"

  if [[ -n "$RUN_ID" && "$RUN_ID" != "null" ]]; then
    break
  fi

  sleep 5
done

if [[ -z "$RUN_ID" || "$RUN_ID" == "null" ]]; then
  echo "Could not find the triggered workflow run." >&2
  exit 1
fi

echo "Watching run: $RUN_ID"
set +e
gh run watch "$RUN_ID" --exit-status
WATCH_STATUS=$?
set -e

echo "Showing failed logs, if any:"
gh run view "$RUN_ID" --log-failed || true

exit "$WATCH_STATUS"
