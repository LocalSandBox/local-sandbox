#!/usr/bin/env bash
set -euo pipefail

host="${WIN_TEST_HOST:-win-test}"
windows_root='C:/dev/local-sandbox-agent'
snapshot_index=''
snapshot_objects=''
runtime_assets_temp=''
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "$script_dir/.." && pwd)"

usage() {
    cat <<'EOF'
Usage:
  scripts/win-test setup
  scripts/win-test verify
  scripts/win-test provision-signing
  scripts/win-test provision-signing-windows
  scripts/win-test verify-signing
  scripts/win-test provision-runtime
  scripts/win-test verify-runtime
  scripts/win-test preflight
  scripts/win-test run -- <executable> [arguments...]
  scripts/win-test suite <suite-name> [--reuse-candidate <run-id>]
  scripts/win-test reboot <suite-name> [--reuse-candidate <run-id>]
  scripts/win-test resume <run-id>
  scripts/win-test fetch <run-id> <new-local-directory>

WIN_TEST_HOST overrides the default SSH alias "win-test".
EOF
}

fail() {
    printf 'win-test: %s\n' "$*" >&2
    exit 2
}

cleanup() {
    if [[ -n "$snapshot_index" && -f "$snapshot_index" ]]; then
        rm -f "$snapshot_index"
    fi
    if [[ -n "$snapshot_objects" && -d "$snapshot_objects" ]]; then
        rm -rf -- "$snapshot_objects"
    fi
    if [[ -n "$runtime_assets_temp" && -d "$runtime_assets_temp" ]]; then
        rm -rf -- "$runtime_assets_temp"
    fi
}
trap cleanup EXIT

validate_host() {
    [[ "$host" =~ ^[A-Za-z0-9._-]+$ ]] || fail 'WIN_TEST_HOST must be an SSH host alias without shell metacharacters'
}

ssh_windows() {
    ssh \
        -o BatchMode=yes \
        -o ConnectTimeout=8 \
        -o ServerAliveInterval=15 \
        -o ServerAliveCountMax=4 \
        "$host" "$@"
}

setup_host() {
    local staging="C:/Windows/Temp/local-sandbox-agent-setup-$$"
    local setup_status=0 cleanup_status=0
    if ssh_windows pwsh -NoProfile -NonInteractive -Command \
        "New-Item -ItemType Directory -Force -Path '$staging' | Out-Null" && \
        scp \
            -o BatchMode=yes \
            -o ConnectTimeout=8 \
            "$script_dir/setup-windows-test-host.ps1" \
            "$script_dir/windows-test-bootstrap.ps1" \
            "$script_dir/windows-test-signing-assets.ps1" \
            "$script_dir/windows-test-runtime-assets.ps1" \
            "$script_dir/windows-test-artifacts.ps1" \
            "${host}:${staging}/" && \
        ssh_windows pwsh -NoProfile -NonInteractive -File \
            "${staging}/setup-windows-test-host.ps1" \
            -BootstrapSource "${staging}/windows-test-bootstrap.ps1" \
            -SigningAssetsSource "${staging}/windows-test-signing-assets.ps1" \
            -RuntimeAssetsSource "${staging}/windows-test-runtime-assets.ps1" \
            -ArtifactFetchSource "${staging}/windows-test-artifacts.ps1" && \
        ssh_windows pwsh -NoProfile -NonInteractive -File \
            "${windows_root}/setup-windows-test-host.ps1" -VerifyOnly; then
        setup_status=0
    else
        setup_status=$?
    fi
    ssh_windows pwsh -NoProfile -NonInteractive -Command \
        "Remove-Item -LiteralPath '$staging' -Recurse -Force -ErrorAction SilentlyContinue" || \
        cleanup_status=$?
    if (( setup_status != 0 )); then
        return "$setup_status"
    fi
    return "$cleanup_status"
}

provision_signing() {
    local pfx_path="${SEAWORK_WINDOWS_PFX_PATH:-}"
    local password_path="${SEAWORK_WINDOWS_PFX_PASSWORD_FILE:-}"
    local stage_name="$(date -u '+%Y%m%dt%H%M%Sz')-$$"
    local remote_stage="C:/ProgramData/LocalSandbox/DevTest/assets/.signing-stage-$stage_name"
    [[ -n "$pfx_path" && -f "$pfx_path" ]] || \
        fail 'SEAWORK_WINDOWS_PFX_PATH must name the local PFX file'
    [[ -n "$password_path" && -f "$password_path" ]] || \
        fail 'SEAWORK_WINDOWS_PFX_PASSWORD_FILE must name the local password file'
    ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/windows-test-signing-assets.ps1" -Mode Prepare -StageName "$stage_name"
    local provision_status=0
    if scp -q -o BatchMode=yes -o ConnectTimeout=8 \
        "$pfx_path" "${host}:${remote_stage}/SeaWork-CodeSign.pfx" && \
        scp -q -o BatchMode=yes -o ConnectTimeout=8 \
        "$password_path" "${host}:${remote_stage}/win_csc_key_password.txt" && \
        ssh_windows pwsh -NoProfile -NonInteractive -File \
            "${windows_root}/windows-test-signing-assets.ps1" -Mode Commit -StageName "$stage_name"; then
        provision_status=0
    else
        provision_status=$?
        ssh_windows pwsh -NoProfile -NonInteractive -File \
            "${windows_root}/windows-test-signing-assets.ps1" -Mode Abort -StageName "$stage_name" || true
    fi
    return "$provision_status"
}

verify_signing() {
    ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/windows-test-signing-assets.ps1" -Mode Verify
}

provision_signing_windows() {
    local source_root="${SEAWORK_WINDOWS_SIGNING_SOURCE_ROOT:-C:/Users/Public/code/private}"
    local stage_name="$(date -u '+%Y%m%dt%H%M%Sz')-$$"
    ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/windows-test-signing-assets.ps1" \
        -Mode ImportLocal -StageName "$stage_name" -SourceRoot "$source_root"
}

provision_runtime() {
    local runtime_root="${LSB_WINDOWS_RUNTIME_ROOT:-}"
    local stage_name="$(date -u '+%Y%m%dt%H%M%Sz')-$$"
    local remote_stage="C:/ProgramData/LocalSandbox/DevTest/assets/.runtime-stage-$stage_name"
    local archive_dir archive_path
    [[ -n "$runtime_root" && -d "$runtime_root" ]] || \
        fail 'LSB_WINDOWS_RUNTIME_ROOT must name the local runtime asset directory'
    for asset_name in Image initramfs.cpio.gz rootfs.ext4; do
        [[ -f "$runtime_root/$asset_name" ]] || fail "runtime asset is missing: $asset_name"
    done
    archive_dir="$(mktemp -d "${TMPDIR:-/tmp}/local-sandbox-runtime-assets.XXXXXX")"
    runtime_assets_temp="$archive_dir"
    archive_path="$archive_dir/runtime-assets.tar.gz"
    COPYFILE_DISABLE=1 tar -czf "$archive_path" -C "$runtime_root" \
        Image initramfs.cpio.gz rootfs.ext4
    ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/windows-test-runtime-assets.ps1" -Mode Prepare -StageName "$stage_name"
    local provision_status=0
    if scp -q -o BatchMode=yes -o ConnectTimeout=8 \
        "$archive_path" "${host}:${remote_stage}/runtime-assets.tar.gz" && \
        ssh_windows pwsh -NoProfile -NonInteractive -File \
            "${windows_root}/windows-test-runtime-assets.ps1" -Mode Commit -StageName "$stage_name"; then
        provision_status=0
    else
        provision_status=$?
        ssh_windows pwsh -NoProfile -NonInteractive -File \
            "${windows_root}/windows-test-runtime-assets.ps1" -Mode Abort -StageName "$stage_name" || true
    fi
    rm -rf -- "$archive_dir"
    runtime_assets_temp=''
    return "$provision_status"
}

verify_runtime() {
    ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/windows-test-runtime-assets.ps1" -Mode Verify
}

fetch_artifacts() {
    local fetch_run_id="$1" destination="$2" listing name expected_sha expected_size observed_sha
    [[ "$fetch_run_id" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,95}$ ]] || fail 'invalid run ID'
    [[ ! -e "$destination" ]] || fail "fetch destination already exists: $destination"
    mkdir -p -- "$destination"
    listing="$(ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/windows-test-artifacts.ps1" -RunId "$fetch_run_id")"
    while IFS=$'\t' read -r name expected_sha expected_size; do
        name="${name//$'\r'/}"
        expected_sha="${expected_sha//$'\r'/}"
        expected_size="${expected_size//$'\r'/}"
        [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._+-]{0,159}$ ]] || fail 'remote artifact name is unsafe'
        [[ "$expected_sha" =~ ^[0-9a-f]{64}$ ]] || fail "remote artifact hash is invalid: $name"
        [[ "$expected_size" =~ ^[0-9]+$ ]] || fail "remote artifact size is invalid: $name"
        scp -q -o BatchMode=yes -o ConnectTimeout=8 \
            "${host}:C:/ProgramData/LocalSandbox/DevTest/runs/${fetch_run_id}/${name}" \
            "$destination/$name"
        [[ "$(wc -c < "$destination/$name" | tr -d ' ')" == "$expected_size" ]] || \
            fail "downloaded artifact size mismatch: $name"
        observed_sha="$(shasum -a 256 "$destination/$name" | awk '{print $1}')"
        [[ "$observed_sha" == "$expected_sha" ]] || fail "downloaded artifact hash mismatch: $name"
    done <<< "$listing"
}

verify_host() {
    ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/setup-windows-test-host.ps1" -VerifyOnly
}

create_snapshot() {
    local base_sha tree_sha message discovered_root git_dir base_objects
    discovered_root="$(git -C "$repo_root" rev-parse --show-toplevel)"
    [[ "$discovered_root" == "$repo_root" ]] || fail "script directory is not inside the expected Git root: $repo_root"
    cd "$repo_root"
    base_sha="$(git rev-parse HEAD)"
    git_dir="$(git rev-parse --absolute-git-dir)"
    base_objects="$git_dir/objects"
    snapshot_index="$(mktemp "${TMPDIR:-/tmp}/local-sandbox-win-test-index.XXXXXX")"
    snapshot_objects="$(mktemp -d "${TMPDIR:-/tmp}/local-sandbox-win-test-objects.XXXXXX")"
    rm -f "$snapshot_index"
    GIT_INDEX_FILE="$snapshot_index" \
        GIT_OBJECT_DIRECTORY="$snapshot_objects" \
        GIT_ALTERNATE_OBJECT_DIRECTORIES="$base_objects" \
        git read-tree HEAD
    GIT_INDEX_FILE="$snapshot_index" \
        GIT_OBJECT_DIRECTORY="$snapshot_objects" \
        GIT_ALTERNATE_OBJECT_DIRECTORIES="$base_objects" \
        git add -A -- .
    tree_sha="$(GIT_INDEX_FILE="$snapshot_index" \
        GIT_OBJECT_DIRECTORY="$snapshot_objects" \
        GIT_ALTERNATE_OBJECT_DIRECTORIES="$base_objects" \
        git write-tree)"
    message="Local Windows test snapshot based on $base_sha"
    snapshot_sha="$(printf '%s\n' "$message" | \
        GIT_OBJECT_DIRECTORY="$snapshot_objects" \
        GIT_ALTERNATE_OBJECT_DIRECTORIES="$base_objects" \
        git commit-tree "$tree_sha" -p "$base_sha")"
    run_id="$(date -u '+%Y%m%dt%H%M%Sz')-$$-${snapshot_sha:0:12}"
    snapshot_ref="refs/heads/snapshots/$run_id"
    GIT_OBJECT_DIRECTORY="$snapshot_objects" \
        GIT_ALTERNATE_OBJECT_DIRECTORIES="$base_objects" \
        git push --quiet --force "${host}:${windows_root}/mirror.git" \
            "$base_sha:refs/heads/snapshot-bases/current" \
            "$snapshot_sha:$snapshot_ref"
    printf 'Windows test run: %s\nSnapshot: %s (base %s)\n' \
        "$run_id" "$snapshot_sha" "$base_sha"
}

encode_command() {
    [[ "$#" -gt 0 ]] || fail 'run requires an executable after --'
    command_spec_base64="$(printf '%s\0' "$@" | base64 | tr -d '\n')"
}

invoke_bootstrap() {
    local mode="$1" suite="$2" command_spec="${3:-}" reuse_run_id="${4:-}"
    local bootstrap_arguments=(
        pwsh -NoProfile -NonInteractive -File
        "${windows_root}/bootstrap.ps1"
        -Mode "$mode"
        -RunId "$run_id"
        -SnapshotSha "$snapshot_sha"
        -SnapshotRef "$snapshot_ref"
        -Suite "$suite"
    )
    if [[ -n "$command_spec" ]]; then
        bootstrap_arguments+=( -CommandSpecBase64 "$command_spec" )
    fi
    if [[ -n "$reuse_run_id" ]]; then
        bootstrap_arguments+=( -ReuseRunId "$reuse_run_id" )
    fi
    ssh_windows "${bootstrap_arguments[@]}"
}

get_boot_id() {
    ssh_windows pwsh -NoProfile -NonInteractive -Command \
        '(Get-CimInstance Win32_OperatingSystem).LastBootUpTime.ToUniversalTime().Ticks.ToString()'
}

wait_for_reboot() {
    local old_boot_id="$1" deadline now observed
    deadline=$(( $(date +%s) + 900 ))
    printf 'Waiting for Windows to reboot and sshd to return...\n'
    while (( $(date +%s) < deadline )); do
        observed="$(get_boot_id 2>/dev/null || true)"
        observed="${observed//$'\r'/}"
        observed="${observed//$'\n'/}"
        if [[ -n "$observed" && "$observed" != "$old_boot_id" ]]; then
            printf 'Windows returned with a new boot identity.\n'
            return 0
        fi
        sleep 5
    done
    fail "Windows did not complete reboot within 15 minutes; resume later with: scripts/win-test resume $run_id"
}

wait_for_interactive_user() {
    local deadline observed
    deadline=$(( $(date +%s) + 900 ))
    printf 'Waiting for the standard-user console session required by the filtered-token proof...\n'
    while (( $(date +%s) < deadline )); do
        observed="$(ssh_windows pwsh -NoProfile -NonInteractive -Command \
            '"(Get-CimInstance Win32_ComputerSystem).UserName"' 2>/dev/null || true)"
        observed="${observed//$'\r'/}"
        observed="${observed//$'\n'/}"
        if [[ -n "$observed" ]]; then
            printf 'Interactive Windows session detected; resuming the exact run.\n'
            return 0
        fi
        sleep 5
    done
    fail "No interactive Windows user signed in within 15 minutes; sign in, then resume with: scripts/win-test resume $run_id"
}

resume_run() {
    local resume_id="$1"
    [[ "$resume_id" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,95}$ ]] || fail 'invalid run ID'
    ssh_windows pwsh -NoProfile -NonInteractive -File \
        "${windows_root}/bootstrap.ps1" -Mode Resume -RunId "$resume_id"
}

validate_host
[[ "$#" -gt 0 ]] || { usage; exit 2; }
action="$1"
shift

case "$action" in
    setup)
        [[ "$#" -eq 0 ]] || fail 'setup takes no arguments'
        setup_host
        ;;
    verify)
        [[ "$#" -eq 0 ]] || fail 'verify takes no arguments'
        verify_host
        ;;
    provision-signing)
        [[ "$#" -eq 0 ]] || fail 'provision-signing takes no arguments'
        provision_signing
        ;;
    provision-signing-windows)
        [[ "$#" -eq 0 ]] || fail 'provision-signing-windows takes no arguments'
        provision_signing_windows
        ;;
    verify-signing)
        [[ "$#" -eq 0 ]] || fail 'verify-signing takes no arguments'
        verify_signing
        ;;
    provision-runtime)
        [[ "$#" -eq 0 ]] || fail 'provision-runtime takes no arguments'
        provision_runtime
        ;;
    verify-runtime)
        [[ "$#" -eq 0 ]] || fail 'verify-runtime takes no arguments'
        verify_runtime
        ;;
    preflight)
        [[ "$#" -eq 0 ]] || fail 'preflight takes no arguments'
        create_snapshot
        invoke_bootstrap Run preflight
        ;;
    run)
        [[ "${1:-}" == '--' ]] || fail 'run syntax is: scripts/win-test run -- <executable> [arguments...]'
        shift
        encode_command "$@"
        create_snapshot
        invoke_bootstrap Run command "$command_spec_base64"
        ;;
    suite)
        [[ "$#" -eq 1 || "$#" -eq 3 ]] || \
            fail 'suite syntax is: scripts/win-test suite <suite-name> [--reuse-candidate <run-id>]'
        [[ "$1" =~ ^[a-z0-9][a-z0-9._-]{0,63}$ ]] || fail 'invalid suite name'
        suite_name="$1"
        reuse_run_id=''
        if [[ "$#" -eq 3 ]]; then
            [[ "$2" == '--reuse-candidate' ]] || fail 'unknown suite option'
            [[ "$3" =~ ^[a-z0-9][a-z0-9._-]{0,95}$ ]] || fail 'invalid reuse candidate run ID'
            reuse_run_id="$3"
        fi
        create_snapshot
        invoke_bootstrap Run "$suite_name" '' "$reuse_run_id"
        ;;
    reboot)
        [[ "$#" -eq 1 || "$#" -eq 3 ]] || \
            fail 'reboot syntax is: scripts/win-test reboot <suite-name> [--reuse-candidate <run-id>]'
        [[ "$1" =~ ^[a-z0-9][a-z0-9._-]{0,63}$ ]] || fail 'invalid suite name'
        suite_name="$1"
        reuse_run_id=''
        if [[ "$#" -eq 3 ]]; then
            [[ "$2" == '--reuse-candidate' ]] || fail 'unknown reboot option'
            [[ "$3" =~ ^[a-z0-9][a-z0-9._-]{0,95}$ ]] || fail 'invalid reuse candidate run ID'
            reuse_run_id="$3"
        fi
        old_boot_id="$(get_boot_id)"
        old_boot_id="${old_boot_id//$'\r'/}"
        old_boot_id="${old_boot_id//$'\n'/}"
        create_snapshot
        invoke_bootstrap Reboot "$suite_name" '' "$reuse_run_id"
        wait_for_reboot "$old_boot_id"
        wait_for_interactive_user
        resume_run "$run_id"
        ;;
    resume)
        [[ "$#" -eq 1 ]] || fail 'resume requires exactly one run ID'
        resume_run "$1"
        ;;
    fetch)
        [[ "$#" -eq 2 ]] || fail 'fetch requires a run ID and a new local destination directory'
        fetch_artifacts "$1" "$2"
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        usage
        fail "unknown action: $action"
        ;;
esac
