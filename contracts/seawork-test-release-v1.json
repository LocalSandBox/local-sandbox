      "absent": ["case \"checkpoint\"", ".checkpoint("],
      "conclusion": "The existing helper boundary proves the normal operation subset and has no reachable checkpoint operation."
    },
    {
      "id": "source.default-network",
      "path": "apps/electron/src/main/ingress-server.ts",
      "contains": ["defaultNetworkEnabled: true"],
      "conclusion": "Normal Electron tool effects require otherwise-safe public networking by default."
    },
    {
      "id": "source.sequential-effects",
