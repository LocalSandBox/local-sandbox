      "contains": ["workspaceMountedFrom: getRunWorkspacePath(run)"],
      "absent": ["ports", "exposeHost", "from:", "checkpoint"],
      "conclusion": "The scheduled normal-effect producer supplies a workspace but no ports, host exposure, or checkpoint input."
    },
    {
