  "source_assertions": [
    {
      "id": "source.baseline-package",
      "path": "packages/local-sandbox-tools/package.json",
      "contains": ["\"@local-sandbox/lsb-nodejs\": \"0.4.6\""],
      "conclusion": "The production adapter baseline is LocalSandbox 0.4.6."
    },
    {
      "id": "source.start-fields",
      "path": "packages/local-sandbox-tools/src/shared.ts",
      "contains": ["instanceId?: string", "from?: string", "ports?: readonly LocalSandboxPortMappingConfig[]", "mounts?: readonly LocalSandboxMountConfig[]", "network?: LocalSandboxNetworkConfig"],
      "conclusion": "Every listed start field is forwarded to Sandbox.start by the production tool runtime."
    },
    {
      "id": "source.default-network",
      "path": "apps/electron/src/main/ingress-server.ts",
      "contains": ["defaultNetworkEnabled: true"],
      "conclusion": "The default production Electron runtime enables outbound networking."
    },
    {
      "id": "source.ports-and-host-exposure",
      "path": "packages/agent-registry/src/agents/main-agent.ts",
      "contains": ["sandboxContext?.ports ?? []", "sandboxContext?.network?.exposeHost ?? []"],
      "conclusion": "Ports and host exposure are persisted and rendered as reachable runtime behavior."
    },
    {
      "id": "source.mount-layout",
      "path": "packages/local-sandbox-tools/src/shared.ts",
      "contains": ["DEFAULT_LOCAL_SANDBOX_WORKSPACE_MOUNT_PATH = \"/workspace\"", "OUTPUT_DIRECTORY_NAME = \"output\"", "LSB_MOUNT_FLAG_RDONLY = 0x1", "agentContext.skills.from"],
      "conclusion": "Workspace, output, skills, overlay, and explicit mounts are production start inputs with fixed guest paths."
    },
    {
      "id": "source.operation-reachability",
      "path": "apps/electron/src/main/sandbox-helper/helper-server.ts",
      "contains": ["case \"startSandbox\"", "case \"exec\"", "case \"spawn\"", "case \"readFile\"", "case \"writeFile\"", "case \"mkdir\"", "case \"killProcess\"", "case \"stopSandbox\""],
      "absent": ["case \"checkpoint\"", ".checkpoint("],
      "conclusion": "The helper boundary proves the reachable operation set and has no checkpoint operation."
    },
    {
      "id": "source.checkpoint-plumbing-only",
      "path": "packages/local-sandbox-tools/src/shared.ts",
      "contains": ["from: normalizeOptionalText(context.from)"],
      "absent": ["checkpoint("],
      "conclusion": "The legacy from value is forwarded generically but this production adapter does not create checkpoints."
    },
    {
      "id": "source.start-retry",
      "path": "packages/local-sandbox-tools/src/shared.ts",
      "contains": ["DEFAULT_SANDBOX_START_ATTEMPTS = 2", "isRetryableSandboxStartupError", "return await starter.start(opts)"],
      "conclusion": "The production adapter blindly replays selected failed starts and requires an at-most-once replacement."
    }
  ],
